{
  "name": "awesome-automl",
  "version": "2026.4.18",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "discover": "tsx src/cli.ts discover",
    "generate": "tsx src/cli.ts generate",
    "refresh-tags": "tsx src/cli.ts refresh-tags",
    "site-data": "tsx src/generator/site-data.ts",
    "bump-version": "node scripts/bump-version.mjs",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@octokit/rest": "^22.0.1",
    "better-sqlite3": "^12.9.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
