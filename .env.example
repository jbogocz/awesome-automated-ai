# Claude API (required for Analysis Agent)
ANTHROPIC_API_KEY=sk-ant-...

# Override Claude model (default: claude-sonnet-4-6)
# ANTHROPIC_MODEL=claude-opus-4-7

# GitHub (required for search + PR creation)
GITHUB_TOKEN=ghp_...
GITHUB_REPO_OWNER=jbogocz
GITHUB_REPO_NAME=awesome-automated-ai

# Local SQLite database path (default: data/curator.db)
DB_PATH=data/curator.db

# Tuning (optional, defaults shown)
MAX_CANDIDATES_PER_RUN=50
SCORE_THRESHOLD_AUTO=70
SCORE_THRESHOLD_QUEUE=50
MAX_PRS_PER_DAY=3
COST_CAP_PER_RUN=10

# Set to "true" to log actions without opening PRs
DRY_RUN=false
